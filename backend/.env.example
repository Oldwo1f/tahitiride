NODE_ENV=development
PORT=3001

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tahiti
DATABASE_PASSWORD=tahiti
DATABASE_NAME=tahiti_ride

JWT_SECRET=change-me-in-production-please-use-a-long-random-value
JWT_EXPIRES_IN=24h

MAPBOX_TOKEN=pk.your-mapbox-public-token

FARE_BASE_XPF=0
FARE_PER_KM_XPF=100
APP_MARGIN_PER_KM_XPF=20
INITIAL_WALLET_BALANCE_XPF=10000

CORS_ORIGIN=http://localhost:3000

PICKUP_MAX_DISTANCE_METERS=50
DROPOFF_MIN_DELAY_SECONDS=30
NEARBY_DRIVERS_RADIUS_METERS=3000

# Admin bootstrap (optional). If set, the first boot will create or promote
# this account to admin. Leave empty to opt out and use `pnpm run admin:create`.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrator

# ---------------------------------------------------------------------------
# Certifications (driver licence + insurance vignette)
# ---------------------------------------------------------------------------
# Where uploaded files are stored on disk. In Docker this directory is
# mounted as a volume (see docker-compose.yml) so files persist across
# container rebuilds.
UPLOAD_DIR=./uploads

# OCR — leave OPENAI_API_KEY empty to fall back on a stub provider that
# always flags submissions as `pending_review` (useful in dev / CI).
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini

# Auto-approval thresholds (0..1). A submission is auto-approved only when
# OCR confidence >= OCR_MIN_CONFIDENCE, the extracted name (license) or
# plate (insurance) matches the profile, AND the document is not expired.
OCR_NAME_SIMILARITY_THRESHOLD=0.85
OCR_MIN_CONFIDENCE=0.8
