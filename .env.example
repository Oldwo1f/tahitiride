# ------------------------------------------------------------------
# Tahiti Ride — docker-compose orchestration (deployment behind Traefik)
# Copy this file to `.env` and fill in your values, then:
#   docker compose build
#   docker compose up -d
# ------------------------------------------------------------------

# ===== Public domains — REQUIRED =====
# Two subdomains: one for the PWA, one for the API.
# Both must point (DNS A/AAAA) to your server before the first run, so that
# Traefik can issue Let's Encrypt certificates.
PUBLIC_DOMAIN=tahitiride.aito-flow.com
PUBLIC_API_DOMAIN=apitahitiride.aito-flow.com

# ===== Traefik integration =====
# Defaults match the Traefik instance running on this server (n8n stack).
# Adjust if you ever move to a different Traefik setup.
TRAEFIK_NETWORK=n8n_default
TRAEFIK_CERTRESOLVER=mytlschallenge
TRAEFIK_ENTRYPOINT_HTTPS=websecure

# ===== Database =====
DATABASE_USER=tahiti
DATABASE_PASSWORD=change-me-please
DATABASE_NAME=tahiti_ride

# ===== Mapbox — REQUIRED (same value in BOTH variables) =====
# Get a public token at https://account.mapbox.com/access-tokens/ (free tier).
# Use the SAME token for both — they are distinct because one runs server-side
# (backend / Map Matching API) and the other is baked into the static frontend
# bundle at `docker compose build` time.
MAPBOX_TOKEN=pk.your-mapbox-public-token
NUXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# ===== Backend security — REQUIRED =====
# Generate a long random secret, e.g.: openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-value-at-least-32-chars
JWT_EXPIRES_IN=24h

# ===== Facebook Login (optional) =====
# Leave empty to disable the "Continue with Facebook" button. Get values
# at https://developers.facebook.com/apps (type "Consumer", add the
# "Facebook Login for the Web" product). Use the SAME App ID for both:
# the backend verifies the access_token against the Graph API, and the
# frontend SDK is initialised with the public App ID at build time.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v20.0
NUXT_PUBLIC_FACEBOOK_APP_ID=

# ===== Pricing (XPF) =====
# FARE_BASE_XPF: flat booking fee, kept by the platform.
# FARE_PER_KM_XPF: total per-km charged to the passenger.
# APP_MARGIN_PER_KM_XPF: portion of the per-km fee kept by the platform; the
#   driver receives (FARE_PER_KM_XPF - APP_MARGIN_PER_KM_XPF) per km.
FARE_BASE_XPF=0
FARE_PER_KM_XPF=100
APP_MARGIN_PER_KM_XPF=20
INITIAL_WALLET_BALANCE_XPF=10000

# ===== Trip / realtime tuning =====
# These are baseline values: an admin can override them at runtime via the
# back-office (/admin/settings) — DB overrides win over env vars.
PICKUP_MAX_DISTANCE_METERS=50
DROPOFF_MIN_DELAY_SECONDS=30
NEARBY_DRIVERS_RADIUS_METERS=3000

# ===== Admin bootstrap (optional) =====
# When set, the backend creates / promotes this account to admin on every boot.
# Leave BOOTSTRAP_ADMIN_EMAIL empty to disable, then create the admin manually
# with: docker compose exec backend node dist/scripts/create-admin.js \
#   --email you@example.com --password 'longpwd' --name 'Admin'
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Administrator

# ===== OCR — driver licence + insurance vignette (optional) =====
# Leave OPENAI_API_KEY empty to disable auto-OCR and fall back on a stub
# that always queues submissions for manual admin review (safe default).
# Costs ~$0.001 per submission with gpt-4o-mini.
# IMPORTANT: docker-compose only reads this file (/var/www/app/.env), NOT
# backend/.env — that one is for non-docker dev runs only.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini

# Auto-approval thresholds (0..1). A submission is auto-approved only when
# OCR confidence >= OCR_MIN_CONFIDENCE, the extracted name (license) or
# plate (insurance) matches the profile, AND the document is not expired.
OCR_NAME_SIMILARITY_THRESHOLD=0.85
OCR_MIN_CONFIDENCE=0.8
