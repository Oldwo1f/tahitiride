# ------------------------------------------------------------------
# Tahiti Ride — docker-compose orchestration
# Copy this file to `.env` and fill in your values, then:
#   docker compose build
#   docker compose up -d
# ------------------------------------------------------------------

# ===== Database =====
DATABASE_USER=tahiti
DATABASE_PASSWORD=change-me-please
DATABASE_NAME=tahiti_ride

# ===== Backend — REQUIRED =====
# Generate a long random secret, e.g.: openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-value-at-least-32-chars
JWT_EXPIRES_IN=24h

# Mapbox server token used by the backend for Map Matching (distance calc).
# Without it, a Haversine fallback is used (less accurate but works).
MAPBOX_TOKEN=

# Pricing (XPF)
FARE_BASE_XPF=200
FARE_PER_KM_XPF=100
INITIAL_WALLET_BALANCE_XPF=10000

# Allowed CORS origins (comma-separated) or '*'. Same-origin via nginx = "*".
CORS_ORIGIN=*

# Trip/realtime tuning
QR_ROTATION_SECONDS=60
PICKUP_MAX_DISTANCE_METERS=50
NEARBY_DRIVERS_RADIUS_METERS=3000

# ===== Frontend — REQUIRED AT BUILD TIME =====
# Get one at https://account.mapbox.com/access-tokens/
# This is baked into the static bundle by `docker compose build`.
# Changing it requires `docker compose build frontend` + `up -d`.
NUXT_PUBLIC_MAPBOX_TOKEN=

# Host port for the PWA (default 80; set 8080 if 80 is taken by apache/etc.)
FRONTEND_PORT=80
