NUXT_PUBLIC_API_BASE=http://localhost:3001
NUXT_PUBLIC_SOCKET_URL=http://localhost:3001
NUXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# Facebook Login — leave empty to hide the "Continue with Facebook" button.
# Same value as the backend FACEBOOK_APP_ID (the App Secret stays server-side).
NUXT_PUBLIC_FACEBOOK_APP_ID=
